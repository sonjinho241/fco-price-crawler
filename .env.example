# 로컬 테스트용 예시. 실제 값을 채운 .env 는 절대 커밋하지 마세요(.gitignore 처리됨).
# 운영(GitHub Actions)에서는 이 파일을 쓰지 않고 repo Secret(DATABASE_URL)으로 주입합니다.

# 🔒 최소권한 전용 롤의 접속 문자열을 사용하세요(슈퍼유저 URL 금지). sql/crawler_role.sql 참고.
# ⚠️ GitHub Actions(운영)에서는 IPv6 미지원 → Supabase "Session pooler"(IPv4) 주소를 쓸 것.
#    유저명은 <role>.<프로젝트ref> 형식(점+ref):
DATABASE_URL=postgresql://fco_crawler.xxxxx:비밀번호@aws-1-ap-northeast-2.pooler.supabase.com:5432/postgres
# (로컬 테스트라면 직접 연결도 가능: postgresql://fco_crawler:비밀번호@db.xxxxx.supabase.co:5432/postgres)

# 아래는 기본값이 있어 보통 생략 가능 (테스트 시에만 조정)
# PRICE_LATEST_STRONGS=1-13
# PRICE_LATEST_WORKERS=10
# PRICE_LATEST_REQUEST_DELAY=0.05
# PRICE_LATEST_LIMIT=20
# SHARD_INDEX=0
# SHARD_COUNT=1
